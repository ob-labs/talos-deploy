# Talos Portal
ENV=LOCAL

# Ports (compose / k3d NodePort mapping)
PORTAL_PORT=3080
NEWAPI_PORT=3081

# Agent Sandbox
AGENT_SANDBOX_VERSION=v0.4.6
SANDBOX_NAMESPACE=sandbox-workspaces

# Upstream LLM (required for claude to work inside sandboxes)
UPSTREAM_API_KEY=              # actual API key for upstream LLM provider
UPSTREAM_BASE_URL=             # base URL, e.g. https://api.anthropic.com
UPSTREAM_CHANNEL_TYPE=1        # 1=OpenAI-compatible, 14=Anthropic native
UPSTREAM_MODELS=claude-opus-4-7,claude-sonnet-4-6,claude-haiku-4-5-20251001

# Optional model aliases — injected as env vars into each sandbox pod
# Set these when your upstream uses non-standard model names (e.g. GLM)
SANDBOX_DEFAULT_OPUS_MODEL=    # e.g. glm-5.1
SANDBOX_DEFAULT_SONNET_MODEL=  # e.g. glm-5
SANDBOX_DEFAULT_HAIKU_MODEL=   # e.g. glm-4.7

# Production
# ENV=PRODUCTION
# PORTAL_DOMAIN=portal.example.com
# REGISTRY=registry.cn-hangzhou.aliyuncs.com/yourns
# SERVER_IP=1.2.3.4
